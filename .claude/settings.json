{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "[ -x \"$HOME/.local/bin/graphify\" ] && \"$HOME/.local/bin/graphify\" hook-guard search || true"
          }
        ]
      },
      {
        "matcher": "Read|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "[ -x \"$HOME/.local/bin/graphify\" ] && \"$HOME/.local/bin/graphify\" hook-guard read || true"
          }
        ]
      }
    ]
  },
  "worktree": {
    "bgIsolation": "none"
  }
}